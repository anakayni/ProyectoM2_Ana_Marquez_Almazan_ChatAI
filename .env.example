# Clave de API de Google Gemini (obtenla en https://aistudio.google.com/app/apikey)
# NUNCA subas el archivo .env real al repositorio.
GEMINI_API_KEY=tu_api_key_de_google_gemini

# (Opcional) Modelo a usar. Por defecto: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Clave de API de Groq, usada como fallback si Gemini falla (obtenla en https://console.groq.com/keys)
GROQ_API_KEY=tu_api_key_de_groq

# (Opcional) Modelo a usar en Groq. Por defecto: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
